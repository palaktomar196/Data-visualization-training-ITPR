# =====================================================
# 11. File Encryption (Basic)
# =====================================================
Algorithm:
1. Start
2. Read file content
3. Encrypt content
4. Save encrypted file
5. Stop

Program:
def encrypt(text, shift):
    result = ""
    for char in text:
        result += chr(ord(char) + shift)
    return result

with open("input.txt", "r") as file:
    data = file.read()

with open("encrypted.txt", "w") as file:
    file.write(encrypt(data, 3))


# =====================================================
# 12. Tail Implementation
# =====================================================
Algorithm:
1. Start
2. Read file lines
3. Input N
4. Display last N lines
5. Stop

Program:
def tail(filename, n):
    with open(filename, "r") as file:
        lines = file.readlines()

    for line in lines[-n:]:
        print(line, end="")

n = int(input("Enter N: "))
tail("input.txt", n)
