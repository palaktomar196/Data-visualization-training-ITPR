# 5. Email Extractor
# =====================================================
Algorithm:
1. Start
2. Read file content
3. Find email addresses
4. Save emails in new file
5. Stop

Program:
import re

def extract_emails():
    with open("data.txt", "r") as file:
        text = file.read()

    emails = re.findall(r'\S+@\S+', text)

    with open("emails.txt", "w") as file:
        for email in emails:
            file.write(email + "\n")

extract_emails()


# =====================================================
# 6. File Merge with Line Numbers
# =====================================================
Algorithm:
1. Start
2. Read both files
3. Merge lines
4. Add line numbers
5. Save merged file
6. Stop

Program:
def merge_files():
    with open("file1.txt", "r") as f1:
        lines1 = f1.readlines()
    with open("file2.txt", "r") as f2:
        lines2 = f2.readlines()

    with open("merged.txt", "w") as f:
        for i, line in enumerate(lines1 + lines2, start=1):
            f.write(str(i) + ". " + line)

merge_files()


