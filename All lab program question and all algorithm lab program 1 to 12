# =====================================================
# 1. Copy File Content
# =====================================================
Algorithm:
1. Start
2. Open source file in read mode
3. Read file content
4. Open destination file in write mode
5. Write content into destination file
6. Display success message
7. Stop

Program:
def copy_file():
    with open("file1.txt", "r") as f1:
        data = f1.read()
    with open("file2.txt", "w") as f2:
        f2.write(data)
    print("File copied successfully")

copy_file()


