import re

def extract_emails():
    with open("data.txt", "r") as file:
        text = file.read()

    emails = re.findall(r'\S+@\S+', text)

    with open("emails.txt", "w") as file:
        for email in emails:
            file.write(email + "\n")

    print("Emails extracted successfully")

extract_emails()
