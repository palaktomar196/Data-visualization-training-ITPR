def merge_files():
    with open("file1.txt", "r") as f1:
        lines1 = f1.readlines()

    with open("file2.txt", "r") as f2:
        lines2 = f2.readlines()

    merged_lines = lines1 + lines2

    with open("merged.txt", "w") as f:
        line_no = 1
        for line in merged_lines:
            f.write(str(line_no) + ". " + line)
            line_no += 1

    print("Files merged successfully")

merge_files()
