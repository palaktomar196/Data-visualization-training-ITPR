# 12. Tail Implementation (Like Linux tail)
# =====================================

def tail(filename, n):
    file = open(filename, "r")
    lines = file.readlines()
    file.close()

    print("Last", n, "lines of the file:")
    for line in lines[-n:]:
        print(line, end="")

filename = "input.txt"
n = int(input("Enter number of last lines to display: "))

tail(filename, n)
