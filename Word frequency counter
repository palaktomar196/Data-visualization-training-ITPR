import string

def word_frequency():
    with open("article.txt", "r") as file:
        text = file.read()

    text = text.lower()

    for p in string.punctuation:
        text = text.replace(p, "")

    words = text.split()

    freq = {}

    for word in words:
        if word in freq:
            freq[word] += 1
        else:
            freq[word] = 1

    for word, count in freq.items():
        print(word, ":", count)

word_frequency()
